# === 拼多多采集器配置 ===

# MySQL数据库配置（留空则使用本地SQLite）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=pdd_monitor

# 设备配置
# 物理手机通过USB连接: 留空 或 填写 serial (adb devices 查看)
# 模拟器: 填写模拟器ADB端口，如 127.0.0.1:7555 (雷电), 127.0.0.1:21503 (夜神)
DEVICE_SERIAL=

# 采集配置
SEARCH_KEYWORD=莜面鱼鱼
MAX_SCROLLS=20
SCROLL_PAUSE_SECONDS=2
MAX_RESULTS=200

# 定时任务 (cron表达式: 分 时 日 月 周)
# 默认每天凌晨2点执行
SCRAPE_CRON=0 2 * * *

# Web服务配置
WEB_HOST=0.0.0.0
WEB_PORT=5000
WEB_DEBUG=false

# ADB路径（通常自动检测，如果不行则手动指定）
# ADB_PATH=C:\platform-tools\adb.exe
